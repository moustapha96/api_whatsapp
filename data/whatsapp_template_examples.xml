<?xml version="1.0" encoding="utf-8"?>
<!-- Exemples de templates WhatsApp -->
<odoo>
    <!-- Template pour envoi factures : 1 seul paramètre = le message (corps entier) -->
    <record id="template_invoice_message" model="whatsapp.template">
        <field name="name">Message simple (factures)</field>
        <field name="wa_name">invoice_message</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Message : {{1}}</field>
        <field name="description">Template pour envoyer un message texte (ex: notification de facture). Envoyé vers WhatsApp Business via « Envoyer les templates vers WhatsApp ».</field>
        <field name="parameter_structure">{"body": [{"index": 1, "type": "text", "label": "Message"}], "header": [], "buttons": []}</field>
    </record>

    <!-- Template 0: Message texte simple -->
    <record id="template_simple_text_message" model="whatsapp.template">
        <field name="name">Message texte simple</field>
        <field name="wa_name">simple_text_message</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Bonjour, ceci est un message simple que vous pouvez envoyer à tout moment. Merci.</field>
        <field name="description">Template simple sans variable. Envoyer vers WhatsApp via le bouton dans la configuration.</field>
    </record>

    <!-- Template 1: Message de bienvenue simple -->
    <record id="template_welcome_simple" model="whatsapp.template">
        <field name="name">Message de bienvenue</field>
        <field name="wa_name">welcome_message</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Bonjour et bienvenue ! Nous sommes à votre disposition.</field>
        <field name="description">Template de bienvenue sans variable.</field>
    </record>

    <!-- Template 2: Notification simple -->
    <record id="template_notification_simple" model="whatsapp.template">
        <field name="name">Notification simple</field>
        <field name="wa_name">simple_notification</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Notification : vous avez un nouveau message.</field>
        <field name="description">Template de notification simple.</field>
    </record>

    <!-- Template 3: Message avec paramètres -->
    <record id="template_message_with_params" model="whatsapp.template">
        <field name="name">Message avec paramètres</field>
        <field name="wa_name">message_with_params</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Bonjour {{1}}, votre commande {{2}} est prête.</field>
        <field name="description">Template avec 2 paramètres : nom et numéro de commande.</field>
        <field name="parameter_structure">{"body": [{"index": 1, "type": "text", "label": "Nom"}, {"index": 2, "type": "text", "label": "Commande"}], "header": [], "buttons": []}</field>
    </record>

    <!-- Template 4: Confirmation de commande -->
    <record id="template_order_confirmation" model="whatsapp.template">
        <field name="name">Confirmation de commande</field>
        <field name="wa_name">order_confirmation</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Votre commande a été enregistrée. Merci pour votre confiance.</field>
        <field name="description">Template de confirmation de commande.</field>
    </record>

    <!-- Template 5: Rappel de rendez-vous -->
    <record id="template_appointment_reminder" model="whatsapp.template">
        <field name="name">Rappel de rendez-vous</field>
        <field name="wa_name">appointment_reminder</field>
        <field name="language_code">fr</field>
        <field name="category">UTILITY</field>
        <field name="status">APPROVED</field>
        <field name="body_text">Rappel : vous avez un rendez-vous prévu. Merci de confirmer votre présence.</field>
        <field name="description">Template de rappel de rendez-vous.</field>
    </record>
</odoo>

